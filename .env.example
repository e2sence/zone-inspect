# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET=CHANGE_ME_generate_with_python_-c_"import_secrets;print(secrets.token_hex(32))"
PORT=5001

# ─── Cloudflare R2 Storage ───────────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=pcb-inspect

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster0.example.mongodb.net/pcb_inspect?retryWrites=true&w=majority

# ─── Public URL (for mobile QR codes) ────────────────────────────────────────
BASE_URL=https://inspect.metaprodtrace.com

# ─── Limits ──────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=128
